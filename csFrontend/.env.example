# Runtime mode (current frontend is mock-first; switch later during backend integration)
NEXT_PUBLIC_API_MODE=mock

# 4-service topology (master is integrated into adminMasterService)
# iamService : 인증/권한/JWT
NEXT_PUBLIC_IAM_BASE=http://localhost:8181

# adminMasterService : 대시보드/접수/수납 + 마스터(직원/코드)
NEXT_PUBLIC_ADMIN_MASTER_BASE=http://localhost:8183

# clinicalService : SOAP/검사오더/최종오더
NEXT_PUBLIC_CLINICAL_BASE=http://localhost:8184

# supportService : worklist/lab/rad/pharm/proc
NEXT_PUBLIC_SUPPORT_BASE=http://localhost:8185

# ---- Compatibility aliases (legacy code/adapter migration) ----
# 필요 시 아래 alias를 ADMIN_MASTER/CLINICAL/SUPPORT 기준으로 동일 값으로 맞춰 사용
NEXT_PUBLIC_ADMIN_BASE=http://localhost:8183
NEXT_PUBLIC_MASTER_BASE=http://localhost:8183
NEXT_PUBLIC_EMR_BASE=http://localhost:8184
NEXT_PUBLIC_ORDER_BASE=http://localhost:8184
NEXT_PUBLIC_WORKLIST_BASE=http://localhost:8185
NEXT_PUBLIC_LAB_BASE=http://localhost:8185
NEXT_PUBLIC_RAD_BASE=http://localhost:8185
NEXT_PUBLIC_PHARM_BASE=http://localhost:8185
